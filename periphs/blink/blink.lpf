BLOCK RESETPATHS;
BLOCK ASYNCPATHS;
LOCATE COMP    "clk" SITE "P6";
IOBUF PORT     "clk" IO_TYPE=LVCMOS33;
FREQUENCY PORT "clk" 25.0 MHz;
LOCATE COMP    "LED" SITE "T6";
IOBUF PORT     "LED" IO_TYPE=LVCMOS33;
LOCATE COMP    "rst" SITE "R7";
IOBUF PORT     "rst" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
#LOCATE COMP    "TXD" SITE "A9";
#IOBUF PORT     "TXD" IO_TYPE=LVCMOS33;
#LOCATE COMP    "RXD" SITE "B9";
#IOBUF PORT     "RXD" IO_TYPE=LVCMOS33;